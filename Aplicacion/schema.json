{
  "title": "IEPC - Registro de Candidatura (MR)",
  "type": "object",
  "properties": {
    "procesoElectoral": {
      "type": "string",
      "enum": [
        "PELC 2026-2027"
      ]
    },
    "candidatura": {
      "type": "object",
      "properties": {
        "principio": {
          "type": "string",
          "enum": [
            "MR",
            "RP"
          ]
        },
        "cargo": {
          "type": "string",
          "enum": [
            "DIPUTACION",
            "AYUNTAMIENTO"
          ]
        }
      },
      "required": [
        "principio",
        "cargo"
      ],
      "additionalProperties": false
    },
    "partido": {
      "type": "object",
      "properties": {
        "siglas": {
          "type": "string",
          "minLength": 2,
          "maxLength": 12,
          "pattern": "^[A-ZÁÉÍÓÚÑ]+$"
        },
        "tipoRegistro": {
          "type": "string",
          "enum": [
            "PARTIDO",
            "COALICION",
            "CANDIDATURA_COMUN"
          ]
        }
      },
      "required": [
        "siglas",
        "tipoRegistro"
      ],
      "additionalProperties": false
    },
    "distrito": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "persona": {
      "type": "object",
      "properties": {
        "nombre": {
          "type": "string",
          "minLength": 5,
          "maxLength": 120
        },
        "curp": {
          "type": "string",
          "pattern": "^[A-Z]{4}[0-9]{6}[HM][A-Z]{5}[0-9A-Z]{2}$"
        },
        "fechaNacimiento": {
          "type": "string",
          "format": "date"
        },
        "genero": {
          "type": "string",
          "enum": [
            "MUJER",
            "HOMBRE",
            "NO_BINARIO"
          ]
        },
        "domicilio": {
          "type": "object",
          "properties": {
            "municipio": {
              "type": "string",
              "minLength": 3,
              "maxLength": 80
            },
            "cp": {
              "type": "string",
              "pattern": "^[0-9]{5}$"
            }
          },
          "required": [
            "municipio",
            "cp"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "nombre",
        "curp",
        "fechaNacimiento",
        "genero",
        "domicilio"
      ],
      "additionalProperties": false
    },
    "accionesAfirmativas": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "DISCAPACIDAD",
          "LGBTTTIQ+",
          "INDIGENA",
          "AFROMEXICANA",
          "JALISCIENSE_EXTRANJERO"
        ]
      }
    },
    "documentos": {
      "type": "object",
      "properties": {
        "ine": {
          "type": "boolean"
        },
        "actaNacimiento": {
          "type": "boolean"
        },
        "aceptacionCandidatura": {
          "type": "boolean"
        },
        "declaracionNoSentencia": {
          "type": "boolean"
        }
      },
      "required": [
        "ine",
        "actaNacimiento",
        "aceptacionCandidatura"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "procesoElectoral",
    "candidatura",
    "partido",
    "distrito",
    "persona",
    "documentos"
  ],
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}